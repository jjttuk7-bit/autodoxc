# autodoxc backend 환경변수
# 이 파일을 .env로 복사하고 값 채우기.

# --- LLM provider (ADR 0010 — OpenAI 1차) ---
# LLM_PROVIDER: "openai" | "anthropic" | "dummy" | "auto"
# - openai: GPT 모델 호출 (OPENAI_API_KEY 필수)
# - anthropic: Claude API 호출 (ANTHROPIC_API_KEY 필수, ADR 0001 — superseded)
# - dummy: 하드코딩 응답 (비용 0)
# - auto: openai 키 있으면 openai, 없으면 anthropic, 없으면 dummy
LLM_PROVIDER=auto

# 키 (둘 다 비워도 dummy로 안전 강등)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# 모델 ID — provider별 기본값 자동 적용. 명시 시 우선.
# OpenAI 권장 (ADR 0010): opus=gpt-4o, sonnet=gpt-4o, haiku=gpt-4o-mini
# Anthropic 권장 (ADR 0001): opus=claude-opus-4-7, sonnet=claude-sonnet-4-6, haiku=claude-haiku-4-5-20251001
LLM_MODEL_OPUS=
LLM_MODEL_SONNET=
LLM_MODEL_HAIKU=

# 세션 토큰 상한 (04-orchestration §8)
LLM_SESSION_TOKEN_BUDGET=200000

# --- 국가법령정보센터 OpenAPI (ADR 0007) ---
# https://open.law.go.kr 가입 후 발급되는 사용자 ID(OC 파라미터)
OPEN_LAW_OC=
OPEN_LAW_FORMAT=JSON
OPEN_LAW_CACHE_TTL=604800

# --- DA3 RAG / DA2 Library — Postgres + pgvector (ADR 0003) ---
# 미설정 시: DB·RAG·임베딩 미사용 (안전 fallback)
DATABASE_URL=postgresql://autodoxc:dev-password@127.0.0.1:5432/autodoxc

# --- 임베딩 (ADR 0002 — 콜드스타트는 OpenAI API) ---
# embedding_mode: "openai" 또는 "dummy" (API 키 없으면 자동 강등)
EMBEDDING_MODE=dummy
# OPENAI_API_KEY는 위와 공유. 임베딩 모델·차원만 별도:
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_EMBEDDING_DIM=3072
